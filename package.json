{
    "name": "saasathon-backend",
    "version": "1.0.0",
    "description": "Backend for SaaSathon Razorpay Integration",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "server": "nodemon server.js",
        "client": "npm run dev --prefix frontend",
        "dev": "concurrently \"npm run server\" \"npm run client\"",
        "build": "npm run build --prefix frontend"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1004.0",
        "body-parser": "^1.20.2",
        "concurrently": "^9.2.1",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "express-rate-limit": "^8.3.0",
        "mongoose": "^9.2.4",
        "multer": "^2.1.1",
        "multer-s3": "^3.0.1",
        "winston": "^3.12.0"
    },
    "devDependencies": {
        "nodemon": "^3.1.0"
    }
}
